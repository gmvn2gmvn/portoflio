<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>gmvn — through the gmvn lens</title>
<meta name="description" content="gmvn — photography and event media coverage.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital@1&family=Inter:wght@400;500&display=swap" rel="stylesheet">
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html, body {
    width: 100%; height: 100%; overflow: hidden;
    background: #050505;
    font-family: 'Inter', sans-serif;
  }
  .stage {
    position: relative;
    width: 100vw; height: 100vh;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    cursor: none;
  }

  .hero {
    position: absolute; inset: -20px;
    width: calc(100% + 40px); height: calc(100% + 40px);
    object-fit: cover;
    object-position: 62% 45%;
    filter: contrast(1.08) brightness(0.85);
  }

  .duotone {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at 50% 50%, rgba(0,0,0,0.15) 0%, rgba(0,0,0,0.72) 75%);
  }

  .grain {
    position: absolute; inset: 0;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='120' height='120'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2' stitchTiles='stitch'/><feColorMatrix type='saturate' values='0'/></filter><rect width='100%25' height='100%25' filter='url(%23n)' opacity='0.5'/></svg>");
    opacity: 0.28;
    mix-blend-mode: overlay;
    pointer-events: none;
  }

  canvas#sprinkle {
    position: absolute; inset: 0;
    pointer-events: none;
    z-index: 4;
  }

  .flicker {
    position: absolute; inset: 0;
    background: #fff;
    opacity: 0;
    pointer-events: none;
    animation: flash 7s ease-in-out infinite;
  }
  @keyframes flash {
    0%, 96%, 100% { opacity: 0; }
    97% { opacity: 0.06; }
    97.5% { opacity: 0; }
    98% { opacity: 0.03; }
    98.5% { opacity: 0; }
  }

  .vignette {
    position: absolute; inset: 0;
    box-shadow: inset 0 0 180px 70px #000;
    pointer-events: none;
  }

  .top-row {
    position: absolute; top: 28px; left: 0; right: 0;
    display: flex; justify-content: center;
    z-index: 5;
  }
  .name {
    font-size: 11px; letter-spacing: 0.16em; color: rgba(255,255,255,0.6);
    text-transform: uppercase;
  }

  .center {
    position: relative; z-index: 5;
    display: flex; flex-direction: column; align-items: center;
    text-align: center; gap: 18px;
  }
  .eyebrow {
    font-size: 11px; letter-spacing: 0.16em; color: rgba(255,255,255,0.5);
    text-transform: uppercase;
  }
  .tagline {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic; font-weight: 400;
    font-size: 42px; color: rgba(255,255,255,0.96);
  }
  .enter {
    margin-top: 6px;
    font-size: 12px; letter-spacing: 0.1em; color: rgba(255,255,255,0.7);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: color 0.3s ease, border-color 0.3s ease;
  }
  .enter:hover { color: #fff; border-color: rgba(255,255,255,0.5); }

  .foot-row {
    position: absolute; bottom: 28px; left: 0; right: 0;
    display: flex; justify-content: center;
    z-index: 5; font-size: 12px; letter-spacing: 0.1em;
    color: rgba(255,255,255,0.4);
  }
  .foot-row a { color: rgba(255,255,255,0.4); text-decoration: none; transition: color 0.3s ease; }
  .foot-row a:hover { color: rgba(255,255,255,0.85); }
  .foot-row .sep { margin: 0 8px; }
</style>
</head>
<body>
  <div class="stage" id="stage">
    <img class="hero" src="data:image/jpeg;base64," alt="">
    <div class="duotone"></div>
    <div class="grain"></div>
    <div class="flicker"></div>
    <canvas id="sprinkle"></canvas>
    <div class="vignette"></div>

    <div class="top-row"><span class="name">Gustavs Skujins</span></div>

    <div class="center">
      <p class="eyebrow">Photography — Event Media</p>
      <h1 class="tagline">through the gmvn lens</h1>
      <a href="#" class="enter">[ Enter ]</a>
    </div>

    <div class="foot-row">
      <a href="#">Instagram</a><span class="sep">·</span><a href="#">LinkedIn</a><span class="sep">·</span><a href="#">CV</a>
    </div>
  </div>

<script>
  const stage = document.getElementById('stage');
  const canvas = document.getElementById('sprinkle');
  const ctx = canvas.getContext('2d');
  function resize() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
  }
  resize();
  window.addEventListener('resize', resize);

  let particles = [];
  let last = null;
  const shades = ['255,255,255', '210,210,210', '160,160,160'];

  stage.addEventListener('mousemove', e => {
    const count = last ? Math.min(4, Math.hypot(e.clientX - last.x, e.clientY - last.y) / 6) : 2;
    for (let i = 0; i < count; i++) {
      particles.push({
        x: e.clientX + (Math.random() - 0.5) * 10,
        y: e.clientY + (Math.random() - 0.5) * 10,
        vx: (Math.random() - 0.5) * 1.4,
        vy: (Math.random() - 0.5) * 1.4 - 0.3,
        size: Math.random() * 2.2 + 0.6,
        life: 1,
        decay: Math.random() * 0.02 + 0.015,
        color: shades[Math.floor(Math.random() * shades.length)]
      });
    }
    last = { x: e.clientX, y: e.clientY };
    if (particles.length > 260) particles = particles.slice(-260);
  });

  stage.addEventListener('touchmove', e => {
    if (!e.touches[0]) return;
    const t = e.touches[0];
    for (let i = 0; i < 3; i++) {
      particles.push({
        x: t.clientX + (Math.random() - 0.5) * 10,
        y: t.clientY + (Math.random() - 0.5) * 10,
        vx: (Math.random() - 0.5) * 1.4,
        vy: (Math.random() - 0.5) * 1.4 - 0.3,
        size: Math.random() * 2.2 + 0.6,
        life: 1,
        decay: Math.random() * 0.02 + 0.015,
        color: shades[Math.floor(Math.random() * shades.length)]
      });
    }
  }, { passive: true });

  function tick() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    particles.forEach(p => {
      p.x += p.vx;
      p.y += p.vy;
      p.vy += 0.01;
      p.life -= p.decay;
      if (p.life > 0) {
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(' + p.color + ',' + p.life + ')';
        ctx.fill();
      }
    });
    particles = particles.filter(p => p.life > 0);
    requestAnimationFrame(tick);
  }
  tick();
</script>
</body>
</html>
